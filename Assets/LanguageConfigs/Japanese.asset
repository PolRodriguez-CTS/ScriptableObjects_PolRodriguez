  texto1: "\u7FFB\u8A33\u30B7\u30B9\u30C6\u30E0\u3078\u3088\u3046\u3053\u305D\u3002 "
  texto2: "\u3053\u308C\u306F\u30B5\u30F3\u30D7\u30EB\u30C6\u30AD\u30B9\u30C8\u3067\u3059\u3002 "
  texto3: "\u3054\u5E0C\u671B\u306E\u8A00\u8A9E\u3092\u9078\u629E\u3057\u3066\u304F\u3060\u3055\u3044\u3002 "
